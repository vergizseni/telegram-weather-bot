import { Telegraf } from 'telegraf';
import dotenv from 'dotenv';
import axios from 'axios';

dotenv.config()// "Прочитай файл .env и запомни все настройки"
const awaitingCity = new Set(); // это коллекция, куда бот складывает ID пользователей, чтобы знать: 
// этим людям он уже предложил ввести город, и следующий их текст — это, скорее всего, название города.

const bot = new Telegraf(process.env.BOT_TOKEN);
//"Создай бота и дай ему пароль из этих настроек"
// Завели двигатель (new Telegraf)

// Обработчик команды /start
bot.command('start', (ctx) => {
    // ctx - контекст сообщения, содержит всю информацию о сообщении и пользователе
    ctx.reply(`Привет, ${ctx.from.first_name}! 👋 
Я твой первый бот. Используй /help чтобы узнать что я умею.`);
});

bot.command('help', (ctx) => {
    ctx.reply(`Доступные команды:
/start - начать работу
/help - получить справку
/weather - узнать погоду`);
});

bot.command('weather', (ctx) => {
    ctx.reply('Напиши название города, чтобы узнать погоду:');
    // Запоминаем, что берем город от этого пользователя
    awaitingCity.add(ctx.from.id); // awaitingCity тут — переменная, в которой хранится множество
    //  ID пользователей, от которых ожидается ввод города.
    // - ctx.from.id — это уникальный идентификатор текущего пользователя в Telegram.
    // - .add() — стандартный метод Set, который добавляет элемент во множество.
});